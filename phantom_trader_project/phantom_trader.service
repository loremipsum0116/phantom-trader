[Unit]
Description=Phantom Trader Paper Trading Bot
After=network.target

[Service]
Type=simple
User=phantom
WorkingDirectory=/opt/phantom_trader
EnvironmentFile=/opt/phantom_trader/.env
ExecStart=/opt/phantom_trader/venv/bin/python main.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
